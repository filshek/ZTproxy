<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/planet_settings">
        <SwitchPreference
            android:defaultValue="false"
            android:key="planet_use_custom"
            android:summary="@string/planet_use_custom_summary"
            android:title="@string/use_custom_planet" />
        <Preference
            android:key="set_planet_file"
            android:title="@string/set_planet_file" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/preferences_network">
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="network_use_cellular_data"
            android:title="@string/preferences_network_use_cell_data" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="network_disable_ipv6"
            android:summary="@string/preferences_network_disable_ipv6_summary"
            android:title="@string/preferences_network_disable_ipv6" />
        <ListPreference
            android:defaultValue="tun"
            android:entries="@array/vpn_mode_entries"
            android:entryValues="@array/vpn_mode_values"
            android:key="vpn_mode"
            android:title="@string/pref_vpn_mode" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/pref_category_socks5">
        <EditTextPreference
            android:defaultValue="1080"
            android:inputType="number"
            android:key="socks5_port"
            android:title="@string/pref_socks5_port" />
        <EditTextPreference
            android:defaultValue=""
            android:key="socks5_username"
            android:title="@string/pref_socks5_username" />
        <EditTextPreference
            android:defaultValue=""
            android:key="socks5_password"
            android:title="@string/pref_socks5_password" />
        <SwitchPreference
            android:defaultValue="false"
            android:key="socks5_enable_auth"
            android:title="@string/pref_socks5_enable_auth" />
    </PreferenceCategory>
</PreferenceScreen>
